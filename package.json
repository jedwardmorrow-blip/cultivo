    "jsbarcode": "^3.12.1",
    "jspdf": "^4.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "pdfjs-dist": "5.4.624",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "react-swipeable": "^7.0.2"
