{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__.*__(execute_sql|apply_migration)",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'set -e; DIR=\"$CLAUDE_PROJECT_DIR/scripts/lineage\"; \"$DIR/bootstrap.sh\" >&2; exec \"$DIR/.venv/bin/python\" \"$DIR/validate_sql.py\"'",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
